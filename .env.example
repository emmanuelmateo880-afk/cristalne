# Database
DATABASE_URL="postgresql://user:password@localhost:5432/cristalne"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-min-32-characters"

# JWT
JWT_SECRET="your-jwt-secret-key-here"

# API
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Google AdSense
NEXT_PUBLIC_GOOGLE_ADSENSE_ID="ca-pub-xxxxxxxxxxxxxxxx"

# PayPal
NEXT_PUBLIC_PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_SECRET="your-paypal-secret"

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxx"
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxx"

# Email (for password reset)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@cristalne.com"

# Image Upload
NEXT_PUBLIC_MAX_UPLOAD_SIZE="52428800"

# Admin
ADMIN_EMAIL="admin@cristalne.com"
